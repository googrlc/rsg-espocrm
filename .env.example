# Copy to .env and fill in (see rsg-espocrm/test-api.sh for curl examples).
# Base URL without trailing slash; /api/v1 is appended automatically if missing.
ESPO_URL=https://your-crm.example.com
ESPO_API_KEY=

# Slack (Hermes --slack, Socket Mode). Create a Slack app: enable Socket Mode,
# add Bot Token Scopes: app_mentions:read, chat:write, im:history, im:read, im:write, channels:history
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-1-
