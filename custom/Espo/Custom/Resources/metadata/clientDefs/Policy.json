{
    "controller": "controllers/record",
    "colors": [],
    "kanbanViewMode": true,
    "statusField": "status",
    "color": "#4a6fa5",
    "iconClass": "fas fa-file-contract",
    "filterList": [
        {"name": "active", "style": "success"},
        {"name": "expiringSoon", "style": "warning"},
        {"name": "expired", "style": "danger"},
        {"name": "commAuto"},
        {"name": "genLiability"},
        {"name": "medicare"},
        {"name": "lifeInsurance"},
        {"name": "personalLines"},
        {"name": "workersComp"},
        {"name": "renewalsDue", "style": "warning"}
    ],
    "boolFilterList": [
        "onlyMy"
    ],
    "kanbanCardView": "custom:views/policy/kanban-card",
    "sidePanels": {
        "detail": [
            {
                "name": "daysRemaining",
                "label": "Days Remaining",
                "view": "custom:views/policy/record/panels/days-remaining",
                "order": 1,
                "sticked": true
            },
            {
                "name": "carrierDetails",
                "label": "Carrier Details",
                "view": "custom:views/policy/record/panels/carrier-details",
                "order": 2
            },
            {
                "name": "quickLinks",
                "label": "Quick Links",
                "view": "custom:views/policy/record/panels/quick-links",
                "order": 3
            },
            {
                "name": "activities",
                "label": "Activities",
                "view": "crm:views/record/panels/activities",
                "aclScope": "Activities",
                "orderBy": "dateStart",
                "orderDirection": "desc",
                "order": 4
            }
        ]
    },
    "dynamicLogic": {
        "fields": {
            "cancellationReason": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "status",
                            "value": "Cancelled"
                        }
                    ]
                },
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "status",
                            "value": "Cancelled"
                        }
                    ]
                }
            },
            "vin": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                {
                                    "type": "equals",
                                    "attribute": "businessType",
                                    "value": "Auto"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "lineOfBusiness",
                                    "value": "Auto"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "lineOfBusiness",
                                    "value": "Personal Auto"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "lineOfBusiness",
                                    "value": "Commercial Auto"
                                }
                            ]
                        }
                    ]
                }
            },
            "propertyAddress": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                {
                                    "type": "equals",
                                    "attribute": "businessType",
                                    "value": "Home"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "lineOfBusiness",
                                    "value": "Home"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "lineOfBusiness",
                                    "value": "Homeowners"
                                }
                            ]
                        }
                    ]
                }
            },
            "underwriter": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "carrierAccountId"
                        }
                    ]
                },
                "required": {
                    "conditionGroup": [
                        {
                            "type": "isNotEmpty",
                            "attribute": "carrierAccountId"
                        }
                    ]
                }
            }
        }
    },
    "relationshipPanels": {
        "activityLogs": {
            "orderBy": "dateTime",
            "orderDirection": "desc",
            "createButton": true,
            "order": 1,
            "label": "Activity Log"
        },
        "renewals": {
            "orderBy": "expirationDate",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 2
        }
    }
}
