{
    "kanbanViewMode": true,
    "statusField": "status",
    "filterList": [
        {"name": "actual", "style": "primary"},
        {"name": "converted", "style": "success"},
        {"name": "dead", "style": "danger"}
    ],
    "boolFilterList": ["onlyMy"],
    "dynamicLogic": {
        "panels": {
            "medicare": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                {"type": "in", "attribute": "industry", "value": ["Medicare", "Health", "Senior Services"]},
                                {"type": "isNotEmpty", "attribute": "dateOfBirth"},
                                {"type": "isTrue", "attribute": "medicareEligible"},
                                {"type": "in", "attribute": "source", "value": ["Medicare Referral", "T65 Campaign"]}
                            ]
                        }
                    ]
                }
            }
        }
    }
}
