{
    "filterList": [
        {"name": "allLeads", "style": "primary"},
        {"name": "newLeads"},
        {"name": "myLeads"},
        {"name": "hotLeads", "style": "danger"},
        {"name": "commercialLeads"},
        {"name": "personalLinesLeads"},
        {"name": "lifeHealthLeads"},
        {"name": "referralLeads"},
        {"name": "websiteLeads"},
        {"name": "noFollowUpDate", "style": "warning"},
        {"name": "overdueFollowUp", "style": "danger"},
        {"name": "futureXDate"},
        {"name": "nurtureLeads", "style": "info"},
        {"name": "disqualifiedLeads", "style": "default"},
        {"name": "convertedLeads", "style": "success"}
    ],
    "boolFilterList": ["onlyMy"],
    "kanbanViewMode": true,
    "statusField": "status",
    "kanbanCardView": "custom:views/lead/kanban-card",
    "dynamicLogic": {
        "panels": {
            "medicare": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                {"type": "in", "attribute": "industry", "value": ["Medicare", "Health", "Senior Services"]},
                                {"type": "isNotEmpty", "attribute": "dateOfBirth"},
                                {"type": "isTrue", "attribute": "medicareEligible"},
                                {"type": "in", "attribute": "source", "value": ["Medicare Referral", "T65 Campaign"]}
                            ]
                        }
                    ]
                }
            }
        }
    }
}
