{
    "filterList": [
        {
            "name": "recentlyCreated"
        },
        {
            "name": "personal"
        },
        {
            "name": "commercial"
        }
    ],
    "boolFilterList": [
        "onlyMy"
    ],
    "views": {
        "detail": "custom:views/contact/record/detail-view"
    },
    "sidePanels": {
        "detail": [
            {
                "name": "recordInfo",
                "label": "Record Info",
                "view": "custom:views/contact/record/panels/record-info",
                "order": 1,
                "sticked": true
            },
            {
                "name": "googleDrive",
                "label": "Google Drive",
                "view": "custom:views/widgets/google-drive-contact",
                "order": 2
            },
            {
                "name": "crossSellFlags",
                "label": "Cross-Sell Flags",
                "view": "custom:views/contact/record/panels/cross-sell-flags",
                "order": 3
            },
            {
                "name": "activities",
                "label": "Activities",
                "view": "crm:views/record/panels/activities",
                "aclScope": "Activities",
                "orderBy": "dateStart",
                "orderDirection": "desc",
                "order": 4
            },
            {
                "name": "history",
                "label": "Activity History",
                "view": "crm:views/record/panels/history",
                "aclScope": "Activities",
                "orderBy": "dateStart",
                "orderDirection": "desc",
                "order": 5
            }
        ]
    },
    "bottomPanels": {
        "detail": []
    },
    "relationshipPanels": {
        "policies": {
            "orderBy": "expirationDate",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 1,
            "label": "Personal Policies",
            "view": "custom:views/contact/record/panels/personal-policies"
        },
        "commissions": {
            "orderBy": "createdAt",
            "orderDirection": "desc",
            "createButton": true,
            "selectButton": true,
            "order": 10
        },
        "renewals": {
            "orderBy": "expirationDate",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 11
        }
    },
    "dynamicLogic": {
        "panels": {
            "medicareLife": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "isTrue",
                            "attribute": "medicareLifeVisible"
                        }
                    ]
                }
            }
        }
    },
    "kanbanViewMode": true,
    "statusField": "clientType"
}
