{
    "controller": "controllers/record",
    "colors": [],
    "iconClass": "fas fa-sync-alt",
    "kanbanViewMode": true,
    "kanbanCardView": "custom:views/renewal/kanban-card",
    "statusField": "pipeline_stage",
    "kanbanStatusIgnoreList": [],
    "filterList": [
        {
            "name": "active",
            "style": "primary"
        },
        {
            "name": "criticalUrgent",
            "style": "danger"
        },
        {
            "name": "commAuto"
        },
        {
            "name": "genLiability"
        },
        {
            "name": "personalLines"
        },
        {
            "name": "medicare"
        },
        {
            "name": "renewed",
            "style": "success"
        },
        {
            "name": "lost",
            "style": "danger"
        }
    ],
    "boolFilterList": [
        "onlyMy",
        "assignedToGretchen",
        "commercialLines",
        "personalLines"
    ],
    "dynamicLogic": {
        "fields": {
            "renewal_premium": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Quote Requested" },
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Proposal Sent" },
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Negotiating" },
                                { "type": "notEmpty", "attribute": "disposition" }
                            ]
                        }
                    ]
                }
            },
            "renewal_proposed_premium": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Quote Requested" },
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Proposal Sent" },
                                { "type": "equals", "attribute": "pipeline_stage", "value": "Negotiating" },
                                { "type": "notEmpty", "attribute": "disposition" }
                            ]
                        }
                    ]
                }
            },
            "carrier_premium_change": {
                "visible": {
                    "conditionGroup": [
                        { "type": "notEmpty", "attribute": "renewal_proposed_premium" }
                    ]
                }
            },
            "disposition": {
                "readOnly": {
                    "conditionGroup": [
                        { "type": "notEmpty", "attribute": "disposition" }
                    ]
                }
            }
        }
    }
}
