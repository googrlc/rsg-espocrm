{
    "controller": "controllers/record",
    "colors": [],
    "iconClass": "fas fa-sync-alt",
    "kanbanViewMode": true,
    "kanbanCardView": "custom:views/renewal/kanban-card",
    "statusField": "stage",
    "kanbanStatusIgnoreList": [
        "Lost"
    ],
    "filterList": [
        {
            "name": "active",
            "style": "primary"
        },
        {
            "name": "criticalUrgent",
            "style": "danger"
        },
        {
            "name": "commAuto"
        },
        {
            "name": "genLiability"
        },
        {
            "name": "personalLines"
        },
        {
            "name": "medicare"
        },
        {
            "name": "renewed",
            "style": "success"
        },
        {
            "name": "lost",
            "style": "danger"
        }
    ],
    "boolFilterList": [
        "onlyMy",
        "assignedToGretchen",
        "commercialLines",
        "personalLines"
    ],
    "dynamicLogic": {
        "fields": {
            "lost_reason": {
                "required": {
                    "conditionGroup": [
                        { "type": "equals", "attribute": "stage", "value": "Lost" }
                    ]
                },
                "visible": {
                    "conditionGroup": [
                        { "type": "equals", "attribute": "stage", "value": "Lost" }
                    ]
                }
            },
            "newPolicy": {
                "visible": {
                    "conditionGroup": [
                        { "type": "equals", "attribute": "stage", "value": "Renewed - Won" }
                    ]
                }
            },
            "renewal_premium": {
                "required": {
                    "conditionGroup": [
                        { "type": "notEquals", "attribute": "stage", "value": "Identified" }
                    ]
                },
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                { "type": "equals", "attribute": "stage", "value": "Quote Requested" },
                                { "type": "equals", "attribute": "stage", "value": "Proposal Sent" },
                                { "type": "equals", "attribute": "stage", "value": "Negotiating" },
                                { "type": "equals", "attribute": "stage", "value": "Renewed - Won" }
                            ]
                        }
                    ]
                }
            },
            "renewal_reviewed": {
                "required": {
                    "conditionGroup": [
                        { "type": "notEquals", "attribute": "stage", "value": "Identified" }
                    ]
                }
            },
            "account_confirmed": {
                "required": {
                    "conditionGroup": [
                        { "type": "notEquals", "attribute": "stage", "value": "Identified" }
                    ]
                }
            },
            "renewal_email_sent": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                { "type": "equals", "attribute": "stage", "value": "Outreach Sent" },
                                { "type": "equals", "attribute": "stage", "value": "Renewed - Won" }
                            ]
                        }
                    ]
                }
            },
            "ams_updated": {
                "required": {
                    "conditionGroup": [
                        { "type": "equals", "attribute": "stage", "value": "Renewed - Won" }
                    ]
                }
            },
            "renewal_notes": {
                "required": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                { "type": "equals", "attribute": "stage", "value": "Renewed - Won" },
                                { "type": "equals", "attribute": "stage", "value": "Lost" }
                            ]
                        }
                    ]
                }
            }
        }
    }
}
