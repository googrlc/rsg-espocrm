{
    "recordViews": {
        "detail": "custom:views/account/record/detail"
    },
    "views": {
        "list": "custom:views/account/list"
    },
    "sidePanels": {
        "detail": [
            {
                "name": "commissionSummary",
                "label": "Commission Summary",
                "view": "custom:views/account/record/panels/commission-summary",
                "order": 1
            },
            {
                "name": "googleDrive",
                "label": "Google Drive",
                "view": "custom:views/account/record/panels/google-drive",
                "order": 2
            },
            {
                "name": "internalIds",
                "label": "Internal IDs",
                "view": "custom:views/account/record/panels/internal-ids",
                "order": 3
            }
        ]
    },
    "relationshipPanels": {
        "policies": {
            "orderBy": "expirationDate",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 1,
            "label": "Policies",
            "layout": [
                {"name": "policyNumber", "link": true},
                {"name": "status"},
                {"name": "expirationDate"},
                {"name": "premiumAmount"},
                {"name": "carrier"}
            ]
        },
        "commissions": {
            "orderBy": "createdAt",
            "orderDirection": "desc",
            "createButton": true,
            "selectButton": true,
            "order": 2,
            "label": "Commissions",
            "layout": [
                {"name": "name", "link": true},
                {"name": "status"},
                {"name": "commissionType"},
                {"name": "estimatedCommission"},
                {"name": "postedAmount"},
                {"name": "paymentReceivedDate"}
            ]
        }
