{
    "statusField": "account_type",
    "recordViews": {
        "detail": "custom:views/account/record/detail"
    },
    "views": {
        "list": "custom:views/account/list"
    },
    "menu": {
        "detail": {
            "buttons": [
                "__APPEND__",
                {
                    "name": "requestCoi",
                    "label": "Request COI",
                    "style": "default",
                    "iconClass": "fas fa-certificate",
                    "acl": "create",
                    "aclScope": "Task",
                    "handler": "custom:handlers/account-request-coi",
                    "actionFunction": "requestCoi"
                }
            ]
        }
    },
    "sidePanels": {
        "detail": [
            {
                "name": "commissionSummary",
                "label": "Commission Summary",
                "view": "custom:views/account/record/panels/commission-summary",
                "order": 1
            },
            {
                "name": "googleDrive",
                "label": "Google Drive",
                "view": "custom:views/account/record/panels/google-drive",
                "order": 2
            },
            {
                "name": "documentLinks",
                "label": "Document Links",
                "view": "custom:views/account/record/panels/document-links",
                "order": 3
            },
            {
                "name": "internalIds",
                "label": "Internal IDs",
                "view": "custom:views/common/record/panels/internal-ids",
                "order": 4
            },
            {
                "name": "recordInfo",
                "label": "Record Info",
                "view": "custom:views/common/record/panels/record-info",
                "order": 5
            }
        ]
    },
    "relationshipPanels": {
        "policies": {
            "orderBy": "expiration_date",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 1,
            "label": "Policies",
            "layout": [
                {"name": "policy_number", "link": true},
                {"name": "status"},
                {"name": "expiration_date"},
                {"name": "premium_amount"},
                {"name": "carrier"}
            ]
        },
        "commissions": {
            "orderBy": "createdAt",
            "orderDirection": "desc",
            "createButton": true,
            "selectButton": true,
            "order": 2,
            "label": "Commissions",
            "layout": [
                {"name": "name", "link": true},
                {"name": "status"},
                {"name": "commissionType"},
                {"name": "estimatedCommission"},
                {"name": "postedAmount"},
                {"name": "paymentReceivedDate"}
            ]
        },
        "tasks": {
            "orderBy": "dateEnd",
            "orderDirection": "asc",
            "createButton": true,
            "selectButton": true,
            "order": 3,
            "label": "Tasks",
            "createAttributeMap": {
                "id": "accountId",
                "name": "accountName"
            },
            "rowActionList": ["complete", "archive"],
            "layout": [
                {"name": "name", "link": true},
                {"name": "status"},
                {"name": "taskType"},
                {"name": "dateEnd"},
                {"name": "assignedUser"},
                {"name": "priority"}
            ]
        }
    }
}
