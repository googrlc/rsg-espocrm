            "type": "date",
            "isCustom": true
        },
        "medicarePartBDate": {
            "type": "date",
            "isCustom": true
        },
        "currentMedicarePlan": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "t65AlertSent": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "readOnly": true
