{
    "fields": {
        "insurance_interest": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "General Liability",
                "Workers Comp",
                "Commercial Property",
                "BOP",
                "Personal Auto",
                "Homeowners",
                "Life",
                "Health",
                "Medicare",
                "Group Benefits",
                "Inland Marine",
                "Multiple",
                "Other"
            ],
            "isCustom": true
        },
        "currently_insured": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "current_carrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "estimated_premium": {
            "type": "currency",
            "isCustom": true
        },
        "priority": {
            "type": "enum",
            "options": [
                "",
                "Hot",
                "Warm",
                "Cold"
            ],
            "isCustom": true,
            "style": {
                "Hot": "danger",
                "Warm": "warning",
                "Cold": "info"
            }
        },
        "intel_ai_summary": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Pre-call intel from Manus prospect intelligence pack"
        },
        "intel_pack_run": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "tooltipText": "Checked when Manus prospect-intelligence-pack has run for this lead"
        },
        "date_of_birth": {
            "type": "date",
            "isCustom": true
        },
        "medicare_eligible": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "medicare_part_a_date": {
            "type": "date",
            "isCustom": true
        },
        "medicare_part_b_date": {
            "type": "date",
            "isCustom": true
        },
        "current_medicare_plan": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "t65_alert_sent": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "readOnly": true
        },
        "status": {
            "type": "enum",
            "options": [
                "New / Uncontacted",
                "Attempting Contact",
                "Connected",
                "Gathering Info",
                "Qualified",
                "Nurture",
                "DNC",
                "Converted"
            ],
            "default": "New / Uncontacted",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "New / Uncontacted": "primary",
                "Attempting Contact": "primary",
                "Connected": "warning",
                "Gathering Info": "warning",
                "Qualified": "success",
                "Nurture": "info",
                "DNC": "danger",
                "Converted": "success"
            },
            "kanbanOrder": [
                "New / Uncontacted",
                "Attempting Contact",
                "Connected",
                "Gathering Info",
                "Qualified",
                "Nurture"
            ]
        },
        "x_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Expiration date of current policy \u2014 used for nurture loop automation"
        },
        "callback_date": {
            "type": "date",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-calculated callback date (Commercial: 90 days prior; Personal: 30 days prior)."
        },
        "sourceOpportunity": {
            "type": "link",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Closed Lost opportunity this nurture lead came from."
        },
        "source": {
            "type": "enum",
            "options": [
                "",
                "Call",
                "Email",
                "Existing Customer",
                "Client Referral",
                "Partner Referral",
                "Public Relations",
                "Web Site",
                "Campaign",
                "Other"
            ],
            "isCustom": true
        }
    },
    "links": {
        "sourceOpportunity": {
            "type": "belongsTo",
            "entity": "Opportunity",
            "isCustom": true
        }
    },
    "convertFields": {
        "Contact": {
            "originalLeadSource": "source"
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "textFilterFields": [
            "name",
            "emailAddress",
            "accountName",
            "phoneNumber"
        ],
        "sortByList": [
            "name",
            "createdAt",
            "modifiedAt",
            "status",
            "source",
            "x_date",
            "callback_date"
        ]
    },
    "kanbanStatusIgnoreList": [
        "DNC",
        "Converted"
    ]
}
