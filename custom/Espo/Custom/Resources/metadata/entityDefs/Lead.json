{
    "fields": {
        "insuranceInterest": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "General Liability",
                "Workers Comp",
                "Commercial Property",
                "BOP",
                "Personal Auto",
                "Homeowners",
                "Life",
                "Health",
                "Medicare",
                "Group Benefits",
                "Inland Marine",
                "Multiple",
                "Other"
            ],
            "isCustom": true
        },
        "currentlyInsured": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "currentCarrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "estimatedPremium": {
            "type": "currency",
            "isCustom": true
        },
        "priority": {
            "type": "enum",
            "options": [
                "",
                "Hot",
                "Warm",
                "Cold"
            ],
            "isCustom": true,
            "style": {
                "Hot": "danger",
                "Warm": "warning",
                "Cold": "info"
            }
        },
        "aiSummary": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Pre-call intel from Manus prospect intelligence pack"
        },
        "intelPackRun": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "tooltipText": "Checked when Manus prospect-intelligence-pack has run for this lead"
        },
        "dateOfBirth": {
            "type": "date",
            "isCustom": true
        },
        "medicareEligible": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "medicarePartADate": {
            "type": "date",
            "isCustom": true
        },
        "medicarePartBDate": {
            "type": "date",
            "isCustom": true
        },
        "currentMedicarePlan": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "t65AlertSent": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "readOnly": true
        },
        "status": {
            "type": "enum",
            "options": [
                "New / Uncontacted",
                "Attempting Contact",
                "Connected",
                "Gathering Info",
                "Qualified",
                "Nurture",
                "DNC",
                "Converted"
            ],
            "default": "New / Uncontacted",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "New / Uncontacted": "primary",
                "Attempting Contact": "primary",
                "Connected": "warning",
                "Gathering Info": "warning",
                "Qualified": "success",
                "Nurture": "info",
                "DNC": "danger",
                "Converted": "success"
            },
            "kanbanOrder": [
                "New / Uncontacted",
                "Attempting Contact",
                "Connected",
                "Gathering Info",
                "Qualified",
                "Nurture"
            ]
        },
        "xDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Expiration date of current policy — used for nurture loop automation"
        }
    },
    "convertFields": {
        "Contact": {
            "originalLeadSource": "source"
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "textFilterFields": [
            "name",
            "emailAddress",
            "accountName",
            "phoneNumber"
        ],
        "sortByList": [
            "name",
            "createdAt",
            "modifiedAt",
            "status",
            "source",
            "xDate"
        ]
    },
    "kanbanStatusIgnoreList": [
        "DNC",
        "Converted"
    ]
}
