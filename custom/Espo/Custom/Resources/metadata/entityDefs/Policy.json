{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 100,
            "required": false,
            "layoutDetailDisabled": true,
            "layoutListDisabled": true,
            "layoutMassUpdateDisabled": true,
            "textFilterDisabled": true
        },
        "policyNumber": {
            "type": "varchar",
            "maxLength": 100,
            "required": false,
            "isCustom": true,
            "tooltipText": "Policy number — primary identifier for this policy record"
        },
        "momentumPolicyId": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "NowCerts/Momentum AMS policy databaseId — primary dedup key for sync. NEVER change this value once set."
        },
        "carrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "lineOfBusiness": {
            "type": "varchar",
            "maxLength": 500,
            "isCustom": true,
            "tooltipText": "Raw string from Momentum — may contain multiple LOBs comma-separated"
        },
        "status": {
            "type": "enum",
            "options": [
                "",
                "Active",
                "Up for Renewal",
                "Renewing",
                "Renewed",
                "Expired",
                "Cancelled",
                "Flat Cancel",
                "Pending Cancel",
                "Non-Renewed",
                "Lapsed"
            ],
            "default": "Active",
            "isCustom": true,
            "audited": true,
            "style": {
                "Active": "success",
                "Up for Renewal": "warning",
                "Renewing": "warning",
                "Renewed": "success",
                "Expired": "default",
                "Cancelled": "danger",
                "Flat Cancel": "danger",
                "Pending Cancel": "warning",
                "Non-Renewed": "danger",
                "Lapsed": "danger"
            },
            "kanbanOrder": [
                "Active",
                "Up for Renewal",
                "Renewing",
                "Renewed",
                "Expired",
                "Cancelled",
                "Pending Cancel"
            ]
        },
        "effectiveDate": {
            "type": "date",
            "isCustom": true
        },
        "expirationDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Renewal trigger date — used by renewal pipeline automation"
        },
        "premiumAmount": {
            "type": "currency",
            "isCustom": true
        },
        "commissionRate": {
            "type": "float",
            "isCustom": true
        },
        "commissionAmount": {
            "type": "currency",
            "isCustom": true,
            "readOnly": true
        },
        "coverageAmount": {
            "type": "currency",
            "isCustom": true
        },
        "deductible": {
            "type": "currency",
            "isCustom": true
        },
        "agencyFee": {
            "type": "currency",
            "isCustom": true
        },
        "businessType": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true
        },
        "policyNotes": {
            "type": "text",
            "isCustom": true
        },
        "bindDate": {
            "type": "date",
            "isCustom": true
        },
        "billingType": {
            "type": "enum",
            "options": [
                "",
                "Direct Bill",
                "Agency Bill",
                "Direct Bill 100",
                "Agency Bill 100"
            ],
            "isCustom": true
        },
        "policyTerm": {
            "type": "int",
            "isCustom": true,
            "tooltipText": "Policy term in months (6 or 12)"
        },
        "cancellationDate": {
            "type": "date",
            "isCustom": true
        },
        "cancellationReason": {
            "type": "text",
            "isCustom": true
        },
        "reinstatementDate": {
            "type": "date",
            "isCustom": true
        },
        "momentumLastSynced": {
            "type": "datetime",
            "isCustom": true
        },
        "syncStatus": {
            "type": "enum",
            "options": [
                "",
                "Synced",
                "Pending",
                "Error",
                "Skipped"
            ],
            "default": "Pending",
            "isCustom": true,
            "style": {
                "Synced": "success",
                "Pending": "warning",
                "Error": "danger",
                "Skipped": "default"
            }
        },
        "acceptedByAmsAt": {
            "type": "datetime",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Timestamp when AMS accepted the latest CRM correction payload."
        },
        "acceptedByAmsBy": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "AMS user or integration identity that accepted the latest CRM correction."
        },
        "amsLockState": {
            "type": "enum",
            "options": [
                "",
                "Unlocked",
                "Pending AMS",
                "Locked by AMS",
                "Rejected by AMS"
            ],
            "default": "Unlocked",
            "isCustom": true,
            "displayAsLabel": true,
            "style": {
                "Unlocked": "success",
                "Pending AMS": "warning",
                "Locked by AMS": "info",
                "Rejected by AMS": "danger"
            },
            "tooltipText": "CRM policy edit lock state controlled by AMS correction acceptance."
        },
        "amsLockReason": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Reason for current AMS lock state, including rejection detail when present."
        },
        "insuredMomentumId": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "insuredDatabaseId from Momentum — used to resolve Account/Contact relation during sync"
        },
        "carrierAccount": {
            "type": "link"
        },
        "daysRemaining": {
            "type": "int",
            "isCustom": true,
            "readOnly": true
        },
        "statusLabel": {
            "type": "enum",
            "options": [
                "",
                "ACTIVE",
                "UNKNOWN",
                "RENEWAL WINDOW",
                "CRITICAL RENEWAL",
                "EXPIRED"
            ],
            "isCustom": true,
            "readOnly": true,
            "displayAsLabel": true,
            "style": {
                "ACTIVE": "success",
                "UNKNOWN": "info",
                "RENEWAL WINDOW": "info",
                "CRITICAL RENEWAL": "warning",
                "EXPIRED": "danger"
            }
        },
        "urgencyIcon": {
            "type": "varchar",
            "maxLength": 8,
            "isCustom": true,
            "readOnly": true
        },
        "carrierPortalUrl": {
            "type": "url",
            "isCustom": true,
            "readOnly": true
        },
        "vin": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true
        },
        "propertyAddress": {
            "type": "text",
            "isCustom": true
        },
        "account": {
            "type": "link"
        },
        "contact": {
            "type": "link"
        },
        "opportunities": {
            "type": "linkMultiple"
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "premiumAtRisk": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Annual premium value at risk if policy lapses — used by renewal outreach automation"
        },
        "urgency": {
            "type": "enum",
            "options": [
                "",
                "Low",
                "Medium",
                "High",
                "Critical"
            ],
            "isCustom": true,
            "tooltipText": "Auto-calculated by n8n renewal workflow based on days to expiration",
            "displayAsLabel": true,
            "style": {
                "Critical": "danger",
                "High": "warning",
                "Medium": "info",
                "Low": "success"
            }
        },
        "lastContactMethod": {
            "type": "enum",
            "options": [
                "",
                "Phone",
                "Email",
                "Text",
                "No Response"
            ],
            "isCustom": true,
            "tooltipText": "Set by renewal outreach automation after each email send"
        },
        "lastContactDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Set by renewal outreach automation after each contact attempt"
        },
        "commissions": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "emailSequenceStarted": {
            "type": "bool",
            "default": false,
            "isCustom": true,
            "tooltipText": "Set to true by renewal outreach automation after first email sent"
        },
        "renewals": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true,
            "tooltipText": "Renewal pipeline records for this expiring policy"
        },
        "renewedFrom": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true,
            "tooltipText": "Renewal records where this is the new/renewed policy"
        },
        "activityLogs": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        }
    },
    "links": {
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "policies",
            "isCustom": true
        },
        "carrierAccount": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "carrierPolicies",
            "isCustom": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "policies",
            "isCustom": true
        },
        "opportunities": {
            "type": "hasMany",
            "entity": "Opportunity",
            "relationName": "policyOpportunity",
            "foreign": "policies",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "commissions": {
            "type": "hasMany",
            "entity": "Commission",
            "foreign": "policy",
            "isCustom": true
        },
        "renewals": {
            "type": "hasMany",
            "entity": "Renewal",
            "foreign": "policy",
            "isCustom": true
        },
        "renewedFrom": {
            "type": "hasMany",
            "entity": "Renewal",
            "foreign": "newPolicy",
            "isCustom": true
        },
        "activityLogs": {
            "type": "hasMany",
            "entity": "ActivityLog",
            "foreign": "policy",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "policyNumber",
        "order": "asc",
        "textFilterFields": [
            "policyNumber",
            "carrier",
            "momentumPolicyId"
        ],
        "sortByList": [
            "policyNumber",
            "createdAt",
            "modifiedAt",
            "effectiveDate",
            "expirationDate",
            "carrier",
            "status",
            "lineOfBusiness"
        ]
    },
    "indexes": {
        "momentumPolicyId": {
            "columns": [
                "momentumPolicyId"
            ]
        },
        "insuredMomentumId": {
            "columns": [
                "insuredMomentumId"
            ]
        }
    },
    "kanbanStatusIgnoreList": [
        "Expired",
        "Cancelled",
        "Flat Cancel",
        "Non-Renewed",
        "Lapsed"
    ]
}
