    "dynamicLogic": {
        "fields": {
            "writtenPremium": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "stage",
                            "value": "Closed Won"
                        }
                    ]
                }
            },
            "commissionRate": {
                "visible": {
