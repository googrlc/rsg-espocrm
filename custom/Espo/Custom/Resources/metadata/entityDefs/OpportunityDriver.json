{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false
        },
        "driverName": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "required": true
        },
        "driverLicenseNumber": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true
        },
        "dateOfBirth": {
            "type": "date",
            "isCustom": true
        },
        "actualAge": {
            "type": "int",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Computed from date of birth"
        },
        "stateIssued": {
            "type": "varchar",
            "maxLength": 50,
            "isCustom": true
        },
        "licenseExpirationDate": {
            "type": "date",
            "isCustom": true
        },
        "vehicle": {
            "type": "link"
        },
        "driverSchedule": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "lineOfBusiness": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "Transportation / Trucking",
                "Personal Auto",
                "Motorcycle",
                "Boat",
                "RV",
                "Garagekeepers",
                "Other"
            ],
            "isCustom": true
        },
        "opportunity": {
            "type": "link",
            "required": true
        },
        "account": {
            "type": "link"
        },
        "relationshipToInsured": {
            "type": "enum",
            "options": [
                "",
                "Self",
                "Spouse",
                "Child",
                "Parent",
                "Sibling",
                "Trust",
                "Estate",
                "Other"
            ],
            "isCustom": true
        },
        "yearsLicensed": {
            "type": "int",
            "isCustom": true,
            "min": 0
        },
        "violationsAccidents": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Violations or accidents (free text)"
        },
        "notes": {
            "type": "text",
            "isCustom": true
        }
    },
    "links": {
        "opportunity": {
            "type": "belongsTo",
            "entity": "Opportunity",
            "foreign": "opportunityDrivers",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "opportunityDrivers",
            "isCustom": true
        },
        "vehicle": {
            "type": "belongsTo",
            "entity": "OpportunityVehicle",
            "foreign": "drivers",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "driverName",
        "order": "asc",
        "textFilterFields": [
            "driverName",
            "driverLicenseNumber",
            "stateIssued"
        ],
        "sortByList": [
            "driverName",
            "name",
            "licenseExpirationDate"
        ]
    },
    "formula": {
        "beforeSaveScript": "\n$dob = entity\\attribute('dateOfBirth');\nifThen(\n    $dob != null && $dob != '',\n    entity\\setAttribute('actualAge', datetime\\diff($dob, datetime\\today(), 'years'))\n);\nifThen(\n    $dob == null || $dob == '',\n    entity\\setAttribute('actualAge', null)\n);\n"
    }
}
