{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false
        },
        "year": {
            "type": "int",
            "isCustom": true
        },
        "make": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "required": true
        },
        "model": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "required": true
        },
        "vin": {
            "type": "varchar",
            "maxLength": 64,
            "isCustom": true
        },
        "mileageDriven": {
            "type": "int",
            "isCustom": true
        },
        "ownershipType": {
            "type": "enum",
            "options": [
                "",
                "Own",
                "Lease"
            ],
            "isCustom": true
        },
        "lineOfBusiness": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "Transportation / Trucking",
                "Personal Auto",
                "Motorcycle",
                "Boat",
                "RV",
                "Garagekeepers",
                "Other"
            ],
            "isCustom": true
        },
        "useType": {
            "type": "enum",
            "options": [
                "",
                "Personal",
                "Business",
                "Commercial",
                "Rideshare",
                "Mixed"
            ],
            "isCustom": true,
            "tooltipText": "Primary use for this vehicle on this opportunity"
        },
        "garagingAddress": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Garaging location for this vehicle"
        },
        "currentPremium": {
            "type": "currency",
            "isCustom": true,
            "defaultCurrency": "USD",
            "tooltipText": "Current policy premium for this vehicle"
        },
        "currentExpiration": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Current policy expiration date"
        },
        "priorClaims": {
            "type": "enum",
            "options": [
                "",
                "None",
                "1",
                "2+"
            ],
            "isCustom": true,
            "tooltipText": "Prior claims in last 3 years"
        },
        "notes": {
            "type": "text",
            "isCustom": true
        },
        "opportunity": {
            "type": "link",
            "required": true
        },
        "account": {
            "type": "link"
        }
    },
    "links": {
        "opportunity": {
            "type": "belongsTo",
            "entity": "Opportunity",
            "foreign": "opportunityVehicles",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "opportunityVehicles",
            "isCustom": true
        },
        "drivers": {
            "type": "hasMany",
            "entity": "OpportunityDriver",
            "foreign": "vehicle",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "textFilterFields": [
            "name",
            "make",
            "model",
            "vin"
        ],
        "sortByList": [
            "name",
            "year",
            "make",
            "model",
            "ownershipType"
        ]
    }
}
