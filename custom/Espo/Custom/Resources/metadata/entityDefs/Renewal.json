{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false,
            "tooltipText": "Auto-generated: {Account} - {LOB} Renewal"
        },
        "policy": {
            "type": "link",
            "required": true,
            "tooltipText": "The expiring policy being renewed"
        },
        "newPolicy": {
            "type": "link",
            "tooltipText": "The renewed policy record once bound. Click the linked policy to view the new carrier, premium, and effective date."
        },
        "account": {
            "type": "link",
            "required": true
        },
        "contact": {
            "type": "link"
        },
        "expiration_date": {
            "type": "date",
            "isCustom": true,
            "audited": true,
            "tooltipText": "Auto-populated from linked Policy expiration_date",
            "dbName": "expirationDate"
        },
        "renewal_effective_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "New policy effective date (usually = expirationDate)",
            "dbName": "renewalEffectiveDate"
        },
        "current_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy premium_amount",
            "dbName": "currentPremium"
        },
        "renewal_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Manually entered when quote is received — blank until then",
            "dbName": "renewalPremium"
        },
        "premium_change": {
            "type": "float",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-calculated: ((renewal - current) / current) * 100 — premium delta %",
            "dbName": "premiumChange"
        },
        "line_of_business": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "Transportation / Trucking",
                "General Liability",
                "Workers Comp",
                "Commercial Property",
                "BOP",
                "Professional Liability",
                "Umbrella",
                "Builders Risk",
                "Inland Marine",
                "Personal Auto",
                "Homeowners",
                "Renters",
                "Condo",
                "Dwelling Fire",
                "Motorcycle",
                "Boat",
                "RV",
                "Life",
                "Health",
                "Medicare",
                "Group Benefits",
                "Garagekeepers",
                "Commercial Package",
                "Other",
                "Commercial Umbrella",
                "Personal Umbrella",
                "Cyber Liability"
            ],
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-populated from linked Policy — not editable",
            "dbName": "lineOfBusiness",
            "isSorted": true
        },
        "carrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy"
        },
        "urgency": {
            "type": "enum",
            "options": [
                "",
                "Critical",
                "High",
                "Medium",
                "Low"
            ],
            "isCustom": true,
            "displayAsLabel": true,
            "tooltipText": "Auto-calculated: Critical <30 days, High 30-60, Medium 60-90, Low 90+. Manual override respected.",
            "style": {
                "Critical": "danger",
                "High": "warning",
                "Medium": "info",
                "Low": "default"
            }
        },
        "renewal_notes": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Free text notes for this renewal cycle",
            "dbName": "renewalNotes"
        },
        "commission_rate": {
            "type": "float",
            "isCustom": true,
            "tooltipText": "Renewal commission rate %",
            "dbName": "commissionRate"
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "tasks": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "commissions": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "carrierAccount": {
            "type": "link",
            "isCustom": true,
            "tooltipText": "Carrier Account (relationship link). Auto-populated from linked Policy."
        },
        "pipeline_stage": {
            "type": "enum",
            "options": [
                "",
                "Identified",
                "Outreach Sent",
                "Quote Requested",
                "Proposal Sent",
                "Negotiating",
                "Closed"
            ],
            "default": "Identified",
            "audited": true,
            "displayAsLabel": true,
            "labelType": "state",
            "isCustom": true,
            "style": {
                "Identified": "default",
                "Outreach Sent": "primary",
                "Quote Requested": "primary",
                "Proposal Sent": "warning",
                "Negotiating": "warning",
                "Closed": "success"
            },
            "customizationOptionsReferenceDisabled": true
        },
        "disposition": {
            "type": "enum",
            "options": [
                "",
                "renewed",
                "rewritten",
                "lost_price",
                "lost_coverage",
                "lost_no_response",
                "do_not_renew"
            ],
            "default": "",
            "audited": true,
            "displayAsLabel": true,
            "isCustom": true,
            "style": {
                "renewed": "success",
                "rewritten": "success",
                "lost_price": "danger",
                "lost_coverage": "danger",
                "lost_no_response": "danger",
                "do_not_renew": "danger"
            },
            "tooltipText": "v6 outcome detail. Renewed/Rewritten = won; lost_* / do_not_renew = lost.",
            "dbName": "disposition"
        },
        "renewal_proposed_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Carrier's proposed renewal premium (AMS-download or agent entry). Source for carrier_premium_change.",
            "dbName": "renewalProposedPremium"
        },
        "carrier_premium_change": {
            "type": "float",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Info-only: ((renewal_proposed_premium - current_premium) / current_premium) * 100. Does NOT drive retention bands.",
            "dbName": "carrierPremiumChange"
        },
        "renewal_proposal_url": {
            "type": "url",
            "isCustom": true,
            "maxLength": 255,
            "tooltipText": "Carrier renewal offer PDF (NowCerts Renewal Center)",
            "dbName": "renewalProposalUrl"
        },
        "carrier_renewal_effective_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Carrier's stated renewal effective date if different from expiration_date",
            "dbName": "carrierRenewalEffectiveDate"
        },
        "renewal_underwriter_name": {
            "type": "varchar",
            "isCustom": true,
            "maxLength": 255,
            "tooltipText": "Underwriter contact name (NowCerts Renewal Center)",
            "dbName": "renewalUnderwriterName"
        },
        "renewal_underwriter_notes": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Underwriter notes (NowCerts Renewal Center)",
            "dbName": "renewalUnderwriterNotes"
        },
        "ams_policy_guid": {
            "type": "varchar",
            "isCustom": true,
            "maxLength": 36,
            "tooltipText": "Canonical NowCerts policy GUID — join key across AMS/Espo/Supabase",
            "dbName": "amsPolicyGuid"
        },
        "ams_insured_guid": {
            "type": "varchar",
            "isCustom": true,
            "maxLength": 36,
            "tooltipText": "NowCerts insured GUID — MCP manage_notes writeback target (populated by syncFromPolicy)",
            "dbName": "amsInsuredGuid"
        },
        "ams_writeback_state": {
            "type": "enum",
            "isCustom": true,
            "options": [
                "pending",
                "queued",
                "succeeded",
                "failed"
            ],
            "default": "pending",
            "displayAsLabel": true,
            "readOnly": true,
            "style": {
                "pending": "warning",
                "queued": "info",
                "succeeded": "success",
                "failed": "danger"
            },
            "tooltipText": "Momentum MCP notes-writeback state (set by Hermes loop)",
            "dbName": "amsWritebackState"
        },
        "ams_writeback_at": {
            "type": "datetime",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Last successful MCP writeback timestamp",
            "dbName": "amsWritebackAt"
        },
        "supabase_event_uuid": {
            "type": "varchar",
            "isCustom": true,
            "maxLength": 36,
            "readOnly": true,
            "tooltipText": "Idempotency key -> renewal_events in Supabase",
            "dbName": "supabaseEventUuid"
        },
        "worksheet": {
            "type": "link",
            "isCustom": true,
            "tooltipText": "1:1 RenewalWorksheet (LOB-typed completion record)"
        }
    },
    "links": {
        "policy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "renewals",
            "isCustom": true
        },
        "newPolicy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "renewedFrom",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "renewals",
            "isCustom": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent",
            "isCustom": true
        },
        "commissions": {
            "type": "hasMany",
            "entity": "Commission",
            "foreign": "renewal",
            "isCustom": true
        },
        "carrierAccount": {
            "type": "belongsTo",
            "entity": "Account",
            "isCustom": true
        },
        "worksheet": {
            "type": "belongsTo",
            "entity": "RenewalWorksheet",
            "foreign": "renewal",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "expiration_date",
        "order": "asc",
        "textFilterFields": [
            "name",
            "carrier"
        ],
        "sortByList": [
            "name",
            "expiration_date",
            "createdAt",
            "modifiedAt",
            "pipeline_stage",
            "urgency",
            "current_premium",
            "carrier",
            "disposition"
        ]
    },
    "indexes": {
        "pipelineStageUrgency": {
            "columns": [
                "pipeline_stage",
                "urgency"
            ]
        },
        "expiration_date": {
            "columns": [
                "expiration_date"
            ]
        },
        "amsPolicyGuid": {
            "columns": [
                "ams_policy_guid"
            ]
        }
    },
    "statusField": "pipeline_stage"
}