{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false,
            "tooltipText": "Auto-generated: {Account} - {LOB} Renewal"
        },
        "pipeline_stage": {
            "type": "enum",
            "options": [
                "",
                "Identified",
                "Outreach Sent",
                "Quote Requested",
                "Proposal Sent",
                "Negotiating"
            ],
            "default": "Identified",
            "audited": true,
            "displayAsLabel": true,
            "labelType": "state",
            "isCustom": true,
            "style": {
                "Identified": "default",
                "Outreach Sent": "primary",
                "Quote Requested": "primary",
                "Proposal Sent": "warning",
                "Negotiating": "warning"
            },
            "customizationOptionsReferenceDisabled": true,
            "dbName": "pipelineStage"
        },
        "disposition": {
            "type": "enum",
            "options": [
                "",
                "renewed",
                "rewritten",
                "lost",
                "dnr"
            ],
            "audited": true,
            "displayAsLabel": true,
            "isCustom": true,
            "tooltipText": "Final outcome of this renewal cycle — set once, triggers commission and Hermes notifications",
            "style": {
                "renewed": "success",
                "rewritten": "primary",
                "lost": "danger",
                "dnr": "warning"
            }
        },
        "policy": {
            "type": "link",
            "required": true,
            "tooltipText": "The expiring policy being renewed"
        },
        "account": {
            "type": "link",
            "required": true
        },
        "contact": {
            "type": "link"
        },
        "expiration_date": {
            "type": "date",
            "isCustom": true,
            "audited": true,
            "tooltipText": "Auto-populated from linked Policy expiration_date",
            "dbName": "expirationDate"
        },
        "renewal_effective_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "New policy effective date (usually = expirationDate)",
            "dbName": "renewalEffectiveDate"
        },
        "current_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy premium_amount",
            "dbName": "currentPremium"
        },
        "renewal_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Manually entered when quote is received \u2014 blank until then",
            "dbName": "renewalPremium"
        },
        "renewal_proposed_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Carrier-quoted proposed premium — used to compute carrier_premium_change before binding",
            "dbName": "renewalProposedPremium"
        },
        "premium_change": {
            "type": "float",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-calculated: ((renewal_premium - current_premium) / current_premium) * 100",
            "dbName": "premiumChange"
        },
        "carrier_premium_change": {
            "type": "float",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-calculated: ((renewal_proposed_premium - current_premium) / current_premium) * 100",
            "dbName": "carrierPremiumChange"
        },
        "line_of_business": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "General Liability",
                "Workers Comp",
                "Commercial Property",
                "BOP",
                "Professional Liability",
                "Umbrella",
                "Builders Risk",
                "Inland Marine",
                "Personal Auto",
                "Homeowners",
                "Renters",
                "Condo",
                "Dwelling Fire",
                "Motorcycle",
                "Boat",
                "RV",
                "Life",
                "Health",
                "Medicare",
                "Group Benefits",
                "Garagekeepers",
                "Commercial Package",
                "Other"
            ],
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-populated from linked Policy \u2014 not editable",
            "dbName": "lineOfBusiness"
        },
        "carrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy"
        },
        "urgency": {
            "type": "enum",
            "options": [
                "",
                "Critical",
                "High",
                "Medium",
                "Low"
            ],
            "isCustom": true,
            "displayAsLabel": true,
            "tooltipText": "Auto-calculated: Critical <30 days, High 30-60, Medium 60-90, Low 90+. Manual override respected.",
            "style": {
                "Critical": "danger",
                "High": "warning",
                "Medium": "info",
                "Low": "default"
            }
        },
        "nc_policy_id": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "NowCerts policy ID mirror",
            "dbName": "ncPolicyId"
        },
        "nc_renewal_id": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "NowCerts renewal ID mirror",
            "dbName": "ncRenewalId"
        },
        "nc_premium": {
            "type": "currency",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "NowCerts premium as of last sync",
            "dbName": "ncPremium"
        },
        "nc_last_sync_at": {
            "type": "datetime",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Timestamp of last NowCerts sync",
            "dbName": "ncLastSyncAt"
        },
        "hermes_task_id": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Hermes task ID linked to this renewal loop",
            "dbName": "hermesTaskId"
        },
        "hermes_sweep_at": {
            "type": "datetime",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Timestamp of last Hermes renewal sweep",
            "dbName": "hermesSweepAt"
        },
        "loop_stage": {
            "type": "enum",
            "options": [
                "",
                "pending",
                "active",
                "worksheet_sent",
                "completed"
            ],
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Hermes loop stage — managed by Hermes, not EspoCRM",
            "dbName": "loopStage"
        },
        "loop_updated_at": {
            "type": "datetime",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Timestamp of last loop stage update from Hermes",
            "dbName": "loopUpdatedAt"
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "tasks": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "commissions": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "worksheets": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        }
    },
    "links": {
        "policy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "renewals",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "renewals",
            "isCustom": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent",
            "isCustom": true
        },
        "commissions": {
            "type": "hasMany",
            "entity": "Commission",
            "foreign": "renewal",
            "isCustom": true
        },
        "worksheets": {
            "type": "hasMany",
            "entity": "RenewalWorksheet",
            "foreign": "renewal",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "expiration_date",
        "order": "asc",
        "textFilterFields": [
            "name",
            "carrier"
        ],
        "sortByList": [
            "name",
            "expiration_date",
            "createdAt",
            "modifiedAt",
            "pipeline_stage",
            "urgency",
            "current_premium",
            "carrier"
        ]
    },
    "indexes": {
        "pipelineStageUrgency": {
            "columns": [
                "pipeline_stage",
                "urgency"
            ]
        },
        "disposition": {
            "columns": [
                "disposition"
            ]
        },
        "expiration_date": {
            "columns": [
                "expiration_date"
            ]
        }
    },
    "statusField": "pipeline_stage"
}
