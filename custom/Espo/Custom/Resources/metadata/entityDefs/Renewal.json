{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false,
            "tooltipText": "Auto-generated: {Account} - {LOB} Renewal"
        },
        "stage": {
            "type": "enum",
            "options": [
                "",
                "Identified",
                "Outreach Sent",
                "Quote Requested",
                "Proposal Sent",
                "Negotiating",
                "Renewed - Won",
                "Lost"
            ],
            "default": "Identified",
            "audited": true,
            "displayAsLabel": true,
            "labelType": "state",
            "isCustom": true,
            "style": {
                "Identified": "default",
                "Outreach Sent": "primary",
                "Quote Requested": "primary",
                "Proposal Sent": "warning",
                "Negotiating": "warning",
                "Renewed - Won": "success",
                "Lost": "danger"
            },
            "customizationOptionsReferenceDisabled": true
        },
        "policy": {
            "type": "link",
            "required": true,
            "tooltipText": "The expiring policy being renewed"
        },
        "newPolicy": {
            "type": "link",
            "tooltipText": "The renewed policy record once bound"
        },
        "account": {
            "type": "link",
            "required": true
        },
        "contact": {
            "type": "link"
        },
        "expiration_date": {
            "type": "date",
            "isCustom": true,
            "audited": true,
            "tooltipText": "Auto-populated from linked Policy expiration_date"
        },
        "renewal_effective_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "New policy effective date (usually = expirationDate)"
        },
        "current_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy premium_amount"
        },
        "renewal_premium": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "Manually entered when quote is received \u2014 blank until then"
        },
        "premium_change": {
            "type": "float",
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-calculated: ((renewal - current) / current) * 100 \u2014 premium delta %"
        },
        "line_of_business": {
            "type": "enum",
            "options": [
                "",
                "Commercial Auto",
                "General Liability",
                "Workers Comp",
                "Commercial Property",
                "BOP",
                "Professional Liability",
                "Umbrella",
                "Builders Risk",
                "Inland Marine",
                "Personal Auto",
                "Homeowners",
                "Renters",
                "Condo",
                "Dwelling Fire",
                "Motorcycle",
                "Boat",
                "RV",
                "Life",
                "Health",
                "Medicare",
                "Group Benefits",
                "Garagekeepers",
                "Commercial Package",
                "Other"
            ],
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Auto-populated from linked Policy \u2014 not editable"
        },
        "carrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "Auto-populated from linked Policy"
        },
        "urgency": {
            "type": "enum",
            "options": [
                "",
                "Critical",
                "High",
                "Medium",
                "Low"
            ],
            "isCustom": true,
            "displayAsLabel": true,
            "tooltipText": "Auto-calculated: Critical <30 days, High 30-60, Medium 60-90, Low 90+. Manual override respected.",
            "style": {
                "Critical": "danger",
                "High": "warning",
                "Medium": "info",
                "Low": "default"
            }
        },
        "last_contact_method": {
            "type": "enum",
            "options": [
                "",
                "Email",
                "Call",
                "Text",
                "In person"
            ],
            "isCustom": true,
            "tooltipText": "Updated when activity is logged"
        },
        "last_contact_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Updated when activity is logged"
        },
        "lost_reason": {
            "type": "enum",
            "options": [
                "",
                "Price",
                "Coverage",
                "Unresponsive",
                "Moved carrier",
                "Other"
            ],
            "isCustom": true,
            "tooltipText": "Required when stage = Lost"
        },
        "renewal_notes": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Free text notes for this renewal cycle"
        },
        "commission_rate": {
            "type": "float",
            "isCustom": true,
            "tooltipText": "Renewal commission rate %"
        },
        "expected_commission": {
            "type": "currency",
            "isCustom": true,
            "tooltipText": "renewalPremium * commissionRate"
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "tasks": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "commissions": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        }
    },
    "links": {
        "policy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "renewals",
            "isCustom": true
        },
        "newPolicy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "renewedFrom",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "renewals",
            "isCustom": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "renewals",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent",
            "isCustom": true
        },
        "commissions": {
            "type": "hasMany",
            "entity": "Commission",
            "foreign": "renewal",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "expiration_date",
        "order": "asc",
        "textFilterFields": [
            "name",
            "carrier"
        ],
        "sortByList": [
            "name",
            "expiration_date",
            "createdAt",
            "modifiedAt",
            "stage",
            "urgency",
            "current_premium",
            "carrier"
        ]
    },
    "indexes": {
        "stageUrgency": {
            "columns": [
                "stage",
                "urgency"
            ]
        },
        "expiration_date": {
            "columns": [
                "expiration_date"
            ]
        }
    },
    "statusField": "stage"
}
