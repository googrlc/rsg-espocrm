{
    "fields": {
        "dateOfBirth": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "momentumClientId": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "NowCerts/Momentum AMS insured database_id — used as sync dedup key"
        },
        "csrName": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "readOnly": true,
            "tooltipText": "Assigned CSR from Momentum AMS (csrName field)"
        },
        "clientType": {
            "type": "enum",
            "options": [
                "",
                "Personal",
                "Commercial",
                "Employee Benefits",
                "Supplemental"
            ],
            "isCustom": true,
            "style": {
                "": null,
                "Personal": null,
                "Commercial": null,
                "Employee Benefits": null,
                "Supplemental": null
            }
        },
        "contactType": {
            "type": "enum",
            "options": [
                "",
                "Client",
                "Prospect",
                "Spouse",
                "Dependent",
                "Business Owner",
                "Underwriter",
                "Marketing Rep",
                "Owner",
                "CFO",
                "CEO",
                "VP",
                "Employee"
            ],
            "isCustom": true,
            "displayAsLabel": true,
            "style": {
                "": null,
                "Client": "success",
                "Prospect": "info",
                "Spouse": "primary",
                "Dependent": "warning",
                "Business Owner": "default",
                "Underwriter": null,
                "Marketing Rep": null,
                "Owner": null,
                "CFO": null,
                "CEO": null,
                "VP": null,
                "Employee": null
            },
            "isSorted": true
        },
        "daysUntil65": {
            "type": "int",
            "isCustom": true,
            "readOnly": true
        },
        "contactDriveFolderUrl": {
            "type": "url",
            "isCustom": true,
            "tooltipText": "Optional override — contact-specific Google Drive folder URL"
        },
        "activityLogs": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "accounts": {
            "type": "linkMultiple",
            "isCustom": true
        },
        "addressCountry": {
            "type": "varchar",
            "notStorable": false,
            "layoutDetailDisabled": true,
            "layoutListDisabled": true
        }
    },
    "links": {
        "activityLogs": {
            "type": "hasMany",
            "entity": "ActivityLog",
            "foreign": "contact",
            "isCustom": true
        },
        "accounts": {
            "type": "hasMany",
            "entity": "Account",
            "relationName": "accountContact",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "maxSize": 25,
        "textFilterFields": [
            "name",
            "emailAddress",
            "phoneNumber",
            "accountName"
        ],
        "sortByList": [
            "name",
            "accountName",
            "contactType",
            "clientType",
            "emailAddress",
            "dateOfBirth",
            "createdAt",
            "modifiedAt"
        ]
    }
}