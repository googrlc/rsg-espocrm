{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": true,
            "tooltipText": "Subject \u2014 short description of the interaction"
        },
        "activityType": {
            "type": "enum",
            "options": [
                "",
                "Email Out",
                "Email In",
                "Call",
                "n8n Automated",
                "Manus AI",
                "Note",
                "Intel Run",
                "Renewal Outreach"
            ],
            "required": true,
            "isCustom": true,
            "displayAsLabel": true,
            "style": {
                "Email Out": "primary",
                "Email In": "success",
                "Call": "warning",
                "n8n Automated": "info",
                "Manus AI": "default",
                "Note": "default",
                "Intel Run": "info",
                "Renewal Outreach": "primary"
            }
        },
        "classification": {
            "type": "enum",
            "options": [
                "",
                "Renewal inquiry",
                "Coverage question",
                "Quote request",
                "Claim related",
                "Payment / billing",
                "Document request",
                "Cancellation / non-renewal notice",
                "Carrier correspondence",
                "Complaint",
                "Onboarding",
                "Marketing outreach",
                "General correspondence"
            ],
            "isCustom": true,
            "displayAsLabel": true,
            "tooltipText": "Required for emails and calls \u2014 enables filtering and reporting"
        },
        "dateTime": {
            "type": "datetime",
            "required": true,
            "default": "javascript: return this.dateTime.getNow(1);",
            "isCustom": true
        },
        "direction": {
            "type": "enum",
            "options": [
                "",
                "Outbound",
                "Inbound"
            ],
            "isCustom": true,
            "tooltipText": "For calls: Outbound (we called) / Inbound (they called)"
        },
        "duration": {
            "type": "int",
            "isCustom": true,
            "tooltipText": "Duration in minutes (calls only)"
        },
        "outcome": {
            "type": "enum",
            "options": [
                "",
                "Connected",
                "No answer voicemail",
                "No answer no voicemail",
                "Wrong number"
            ],
            "isCustom": true,
            "tooltipText": "Call outcome (calls only)"
        },
        "notes": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Call notes, email snippet, or intel summary"
        },
        "loggedBy": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "User name for manual, system name (n8n / Manus) for automated"
        },
        "followUpTask": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "If filled, auto-creates a Task linked to this account on save"
        },
        "account": {
            "type": "link",
            "required": true
        },
        "contact": {
            "type": "link"
        },
        "policy": {
            "type": "link"
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "activityLogs",
            "isCustom": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "activityLogs",
            "isCustom": true
        },
        "policy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "activityLogs",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "dateTime",
        "order": "desc",
        "textFilterFields": [
            "name",
            "notes"
        ],
        "sortByList": [
            "dateTime",
            "createdAt",
            "activityType",
            "classification"
        ]
    },
    "indexes": {
        "accountDateTime": {
            "columns": [
                "accountId",
                "dateTime"
            ]
        },
        "contactDateTime": {
            "columns": [
                "contactId",
                "dateTime"
            ]
        }
    }
}