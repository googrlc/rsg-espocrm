{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 255,
            "required": false,
            "tooltipText": "Auto: {Account} {LOB} worksheet"
        },
        "lob_variant": {
            "type": "enum",
            "isCustom": true,
            "audited": true,
            "displayAsLabel": true,
            "options": [
                "personal_auto",
                "homeowners",
                "commercial_auto",
                "general_liability",
                "workers_comp",
                "default"
            ],
            "default": "default",
            "style": {
                "personal_auto": "info",
                "homeowners": "info",
                "commercial_auto": "info",
                "general_liability": "info",
                "workers_comp": "info",
                "default": "default"
            },
            "tooltipText": "LOB discriminator — drives which variant fields are shown. Locked once completion state != not_started.",
            "dbName": "lobVariant"
        },
        "completion_type": {
            "type": "enum",
            "isCustom": true,
            "readOnly": true,
            "options": [
                "",
                "full_review",
                "contact_only"
            ],
            "default": "",
            "tooltipText": "Hidden system field — derived by SubmitWorksheet. Two-tier gate: won/rewritten needs full_review; lost/DNR accepts contact_only.",
            "dbName": "completionType"
        },
        "state": {
            "type": "enum",
            "isCustom": true,
            "audited": true,
            "displayAsLabel": true,
            "labelType": "state",
            "options": [
                "not_started",
                "in_progress",
                "completed"
            ],
            "default": "not_started",
            "style": {
                "not_started": "default",
                "in_progress": "warning",
                "completed": "success"
            },
            "tooltipText": "Auto-progressed: not_started -> in_progress on first edit; locked once past not_started.",
            "dbName": "state"
        },
        "renewal": {
            "type": "link",
            "required": true,
            "tooltipText": "The Renewal this worksheet completes (1:1)."
        },
        "account": {
            "type": "link",
            "readOnly": true,
            "tooltipText": "Auto from linked Renewal — used for ACL scope."
        },
        "assignedUser": {
            "type": "link"
        },
        "teams": {
            "type": "linkMultiple"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "overall_notes": {
            "type": "text",
            "isCustom": true,
            "tooltipText": "Replaces legacy Renewal.renewal_notes",
            "dbName": "overallNotes"
        },
        "client_contacted": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "tooltipText": "Required for any disposition (won or lost)",
            "dbName": "clientContacted"
        },
        "client_contact_date": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Replaces legacy Renewal.last_contact_date",
            "dbName": "clientContactDate"
        },
        "client_contact_method": {
            "type": "enum",
            "isCustom": true,
            "options": [
                "",
                "email",
                "call",
                "text",
                "in_person"
            ],
            "default": "",
            "displayAsLabel": true,
            "tooltipText": "How the client was contacted",
            "dbName": "clientContactMethod"
        },
        "no_contact_reason": {
            "type": "enum",
            "isCustom": true,
            "options": [
                "",
                "client_unresponsive",
                "no_valid_contact_info",
                "carrier_nonrenew_before_outreach",
                "other"
            ],
            "default": "",
            "displayAsLabel": true,
            "tooltipText": "Required when client_contacted=false",
            "dbName": "noContactReason"
        },
