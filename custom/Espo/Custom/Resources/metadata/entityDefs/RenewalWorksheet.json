    "links": {
        "renewal": {
            "type": "belongsTo",
            "entity": "Renewal",
            "foreign": "worksheet",
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "isCustom": true
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "sortByList": [
            "name",
            "createdAt",
            "modifiedAt",
            "state",
            "lob_variant"
        ]
    },
    "indexes": {
