{
    "fields": {
        "dateOfBirth": {
            "type": "date",
            "isCustom": true
        },
        "momentumClientId": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "NowCerts/Momentum AMS insured database_id \u2014 used as sync dedup key"
        },
        "csrName": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true,
            "tooltipText": "Assigned CSR from Momentum AMS (csrName field)"
        },
        "clientType": {
            "type": "enum",
            "options": [
                "",
                "Personal",
                "Commercial"
            ],
            "isCustom": true
        },
        "householdRole": {
            "type": "enum",
            "options": [
                "",
                "Primary",
                "Spouse",
                "Dependent",
                "Co-insured"
            ],
            "isCustom": true,
            "style": {
                "Primary": "primary",
                "Spouse": "success",
                "Dependent": "info",
                "Co-insured": "warning"
            }
        },
        "policies": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "commissions": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "renewals": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "contactDriveFolderUrl": {
            "type": "url",
            "isCustom": true,
            "tooltipText": "Optional override \u2014 contact-specific Google Drive folder URL"
        },
        "medicareEligible": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "medicarePartB": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "medicarePlanType": {
            "type": "enum",
            "options": [
                "",
                "Supplement",
                "Advantage",
                "Part D"
            ],
            "isCustom": true
        },
        "medicareCarrier": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "irmaApplies": {
            "type": "bool",
            "isCustom": true,
            "default": false,
            "tooltipText": "Income-Related Monthly Adjustment Amount applies"
        },
        "aepSepDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Annual Enrollment Period or Special Enrollment Period date"
        },
        "lifeCoverageInForce": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "lifeFaceAmount": {
            "type": "currency",
            "isCustom": true
        },
        "lifePolicyType": {
            "type": "enum",
            "options": [
                "",
                "Term",
                "Whole",
                "Universal"
            ],
            "isCustom": true
        },
        "lifeHealthClass": {
            "type": "enum",
            "options": [
                "",
                "Preferred Plus",
                "Preferred",
                "Standard Plus",
                "Standard",
                "Substandard"
            ],
            "isCustom": true
        },
        "lifeAnnualPremium": {
            "type": "currency",
            "isCustom": true
        },
        "lifeBeneficiaryOnFile": {
            "type": "bool",
            "isCustom": true,
            "default": false
        },
        "lifeReviewDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Last date life insurance review was completed"
        },
        "activityLogs": {
            "type": "linkMultiple",
            "isCustom": true,
            "layoutDetailDisabled": true,
            "noLoad": true
        },
        "accounts": {
            "type": "linkMultiple",
            "isCustom": true
        },
        "addressCountry": {
            "type": "varchar",
            "notStorable": false,
            "layoutDetailDisabled": true,
            "layoutListDisabled": true
        }
    },
    "links": {
        "policies": {
            "type": "hasMany",
            "entity": "Policy",
            "foreign": "contact",
            "isCustom": true
        },
        "commissions": {
            "type": "hasMany",
            "entity": "Commission",
            "foreign": "contact",
            "isCustom": true
        },
        "renewals": {
            "type": "hasMany",
            "entity": "Renewal",
            "foreign": "contact",
            "isCustom": true
        },
        "activityLogs": {
            "type": "hasMany",
            "entity": "ActivityLog",
            "foreign": "contact",
            "isCustom": true
        },
        "accounts": {
            "type": "hasMany",
            "entity": "Account",
            "relationName": "accountContact",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "maxSize": 25,
        "textFilterFields": [
            "name",
            "emailAddress",
            "phoneNumber",
            "accountName"
        ],
        "sortByList": [
            "name",
            "accountName",
            "householdRole",
            "clientType",
            "emailAddress",
            "dateOfBirth",
            "createdAt",
            "modifiedAt"
        ]
    }
}