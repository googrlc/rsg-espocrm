{
    "controller": "controllers/record",
    "kanbanViewMode": true,
    "statusField": "status",
    "color": "#4a6fa5",
    "iconClass": "fas fa-file-contract",
    "filterList": [
        {"name": "active", "style": "success"},
        {"name": "expiringSoon", "style": "warning"},
        {"name": "expired", "style": "danger"},
        {"name": "commAuto"},
        {"name": "genLiability"},
        {"name": "medicare"},
        {"name": "lifeInsurance"},
        {"name": "personalLines"},
        {"name": "workersComp"},
        {"name": "renewalsDue", "style": "warning"}
    ],
    "boolFilterList": [
        "onlyMy"
    ],
    "views": {
        "detail": "custom:views/policy/record/detail-view"
    },
    "sidePanels": {
        "detail": [
            {
                "name": "financials",
                "label": "Financials",
                "view": "custom:views/policy/record/panels/financials",
                "order": 1,
                "sticked": true
            },
            {
                "name": "renewalUrgency",
                "label": "Renewal Status",
                "view": "custom:views/policy/record/panels/renewal-urgency",
                "order": 2
            },
            {
                "name": "syncStatus",
                "label": "NowCerts Sync",
                "view": "custom:views/policy/record/panels/sync-status",
                "order": 3
            },
            {
                "name": "activities",
                "label": "Activities",
                "view": "crm:views/record/panels/activities",
                "aclScope": "Activities",
                "orderBy": "dateStart",
                "orderDirection": "desc",
                "order": 4
            }
        ]
    },
    "relationshipPanels": {
        "activityLogs": {
            "orderBy": "dateTime",
            "orderDirection": "desc",
            "createButton": true,
            "order": 1,
            "label": "Activity Log"
        }
    }
}
