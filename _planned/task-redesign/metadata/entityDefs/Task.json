{
    "fields": {
        "taskType": {
            "type": "enum",
            "options": [
                "Client Service",
                "Policy Change",
                "Renewal",
                "New Business",
                "Follow Up",
                "Onboarding",
                "Claims",
                "Commission",
                "Underwriting Request",
                "Underwriter Follow-up",
                "Agency Admin",
                "Admin",
                "Other"
            ],
            "displayAsLabel": true,
            "audited": true
        },
        "syncSource": {
            "type": "enum",
            "options": [
                "Manual",
                "Email",
                "API",
                "Slack",
                "Momentum",
                "n8n",
                "Hermes"
            ],
            "displayAsLabel": true
        },
        "policyType": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "Line of business / policy type. Auto-populated from the linked Policy where possible."
        },
        "policyNumber": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "Policy number this task concerns. Auto-populated from the linked Policy where possible."
        },
        "carrier": {
            "type": "varchar",
            "maxLength": 150,
            "isCustom": true,
            "tooltipText": "Carrier for the policy. Auto-populated from the linked Policy where possible."
        },
        "policyEffectiveDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Policy period start. Auto-populated from the linked Policy where possible."
        },
        "policyExpirationDate": {
            "type": "date",
            "isCustom": true,
            "tooltipText": "Policy period end. Auto-populated from the linked Policy where possible."
        },
        "refLink": {
            "type": "url",
            "isCustom": true,
            "tooltipText": "Primary external link / portal needed to act on this task (e.g. carrier or audit portal)."
        },
        "refLink2": {
            "type": "url",
            "isCustom": true,
            "tooltipText": "Secondary external link, if any."
        },
        "refNumber": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "Primary reference / assignment / claim number."
        },
        "refNumber2": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "Secondary reference number, if any."
        },
        "refAccessCode": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltipText": "Access code / PIN / credential needed to complete the task."
        },
        "refSupportContact": {
            "type": "varchar",
            "maxLength": 150,
            "isCustom": true,
            "tooltipText": "Support contact or vendor email for this task."
        },
        "refNotes": {
            "type": "text",
            "rowsMin": 2,
            "isCustom": true,
            "tooltipText": "Any other structured reference data needed to act on the task."
        },
        "confirm1Label": {
            "type": "varchar",
            "maxLength": 200,
            "isCustom": true,
            "tooltipText": "Confirmation item 1 — the action that must be confirmed."
        },
        "confirm1Status": {
            "type": "enum",
            "options": ["Pending", "Confirmed", "Needs Follow-up"],
            "default": "Pending",
            "style": {
                "Pending": "default",
                "Confirmed": "success",
                "Needs Follow-up": "warning"
            },
            "displayAsLabel": true,
            "audited": true,
            "isCustom": true
        },
        "confirm1Note": {
            "type": "text",
            "rowsMin": 1,
            "isCustom": true,
            "tooltipText": "How / when / by whom item 1 was confirmed."
        },
        "confirm2Label": {
            "type": "varchar",
            "maxLength": 200,
            "isCustom": true
        },
        "confirm2Status": {
            "type": "enum",
            "options": ["Pending", "Confirmed", "Needs Follow-up"],
            "default": "Pending",
            "style": {
                "Pending": "default",
                "Confirmed": "success",
                "Needs Follow-up": "warning"
            },
            "displayAsLabel": true,
            "audited": true,
            "isCustom": true
        },
        "confirm2Note": {
            "type": "text",
            "rowsMin": 1,
            "isCustom": true
        },
        "confirm3Label": {
            "type": "varchar",
            "maxLength": 200,
            "isCustom": true
        },
        "confirm3Status": {
            "type": "enum",
            "options": ["Pending", "Confirmed", "Needs Follow-up"],
            "default": "Pending",
            "style": {
                "Pending": "default",
                "Confirmed": "success",
                "Needs Follow-up": "warning"
            },
            "displayAsLabel": true,
            "audited": true,
            "isCustom": true
        },
        "confirm3Note": {
            "type": "text",
            "rowsMin": 1,
            "isCustom": true
        },
        "confirm4Label": {
            "type": "varchar",
            "maxLength": 200,
            "isCustom": true
        },
        "confirm4Status": {
            "type": "enum",
            "options": ["Pending", "Confirmed", "Needs Follow-up"],
            "default": "Pending",
            "style": {
                "Pending": "default",
                "Confirmed": "success",
                "Needs Follow-up": "warning"
            },
            "displayAsLabel": true,
            "audited": true,
            "isCustom": true
        },
        "confirm4Note": {
            "type": "text",
            "rowsMin": 1,
            "isCustom": true
        },
        "confirmationProgress": {
            "type": "varchar",
            "maxLength": 16,
            "isCustom": true,
            "readOnly": true,
            "layoutMassUpdateDisabled": true,
            "tooltipText": "Confirmation checklist progress (e.g. \"1/2\"). Maintained automatically by a hook."
        },
        "managerNotes": {
            "type": "wysiwyg",
            "isCustom": true,
            "tooltipText": "Notes from the task creator / manager. Editable by the creator or a manager; read-only for the assignee."
        }
    },
    "links": {
        "policy": {
            "type": "belongsTo",
            "entity": "Policy",
            "foreign": "tasks",
            "isCustom": true
        }
    }
}
